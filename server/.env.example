# Base de données PostgreSQL
# Local (pgAdmin): postgresql://user:password@localhost:5432/vote_iai
# Supabase: voir docs/SUPABASE_POSTGRES.md (URL pooler + ?sslmode=require)
# Railway: voir docs/RAILWAY_POSTGRES.md
DATABASE_URL="postgresql://user:password@localhost:5432/vote_iai"

# NotchPay (Settings > API Keys sur business.notchpay.co)
# Clé secrète : pour créer les paiements (POST /payments, PUT /payments/:id)
NOTCHPAY_SECRET_KEY=
# Clé publique : pour l’API Resources (pays, canaux). Si vide, la secrète est utilisée.
# Si /api/notchpay/countries et /channels renvoient vide, définir NOTCHPAY_PUBLIC_KEY avec ta clé publique.
NOTCHPAY_PUBLIC_KEY=

# URL du frontend public (callback + CORS)
APP_URL=http://localhost:5173

# URL du frontend admin (CORS). Ex: https://vote-iai-admin.vercel.app
ADMIN_APP_URL=

# Secret pour les routes admin (header: x-admin-secret). Pas de comptes utilisateurs.
ADMIN_SECRET=

# PORT (Railway le définit automatiquement)

POPULAR_TOP_N = 3

VITE_STRIPE_PUBLIC_KEY=pk_test_...   # ta clé publique dans Stripe Dashboard → Développeurs → Clés API
STRIPE_SECRET_KEY=sk_live_...     # ou sk_test_... pour les tests
STRIPE_WEBHOOK_SECRET=whsec_...   # obtenu dans le dashboard Stripe
